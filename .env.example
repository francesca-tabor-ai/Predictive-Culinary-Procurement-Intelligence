# Backend
DATABASE_URL=postgresql://user:password@localhost:5432/pci
# Or use DATABASE_PUBLIC_URL for external DB (e.g. Railway, Supabase)
# DATABASE_PUBLIC_URL=postgresql://...

JWT_SECRET=your-secure-random-secret-change-in-production

# Frontend - API base URL (optional)
# Leave unset: dev uses Vite proxy; production assumes API at same origin (/api, /auth)
# Set if API is on a different origin: VITE_API_URL=https://api.yourdomain.com

# AI Intelligence (optional)
# Gemini API key for ingredient intelligence and menu optimization
# Get from https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-api-key
